rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function isOwnerEmail() {
      return isSignedIn()
        && 'email' in request.auth.token
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'giathieu110406@gmail.com';
    }

    function isAdminDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdminRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function isAdmin() {
      return isOwnerEmail() || isAdminDoc() || isAdminRole();
    }

    // Owner: full access toàn bộ database
    match /{document=**} {
      allow read, write: if isOwnerEmail();
    }

    // Collection admins: chỉ đọc được nếu là admin, không ai write được từ client
    match /admins/{uid} {
      allow read: if true;
      allow write: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow get:    if isSignedIn() && (currentUid() == userId || isAdmin());
      allow list:   if isAdmin();
      allow create: if isSignedIn() && currentUid() == userId;
      allow update: if isSignedIn() && (currentUid() == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /feedbacks/{feedbackId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn() && (resource.data.uid == currentUid() || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    match /saved_documents/{documentId} {
      allow create: if isSignedIn() && (request.resource.data.userId == currentUid() || isAdmin());
      allow read:   if isSignedIn() && (resource.data.userId == currentUid() || isAdmin());
      allow update: if isSignedIn() && resource.data.userId == currentUid() && request.resource.data.userId == currentUid();
      allow delete: if isSignedIn() && (resource.data.userId == currentUid() || isAdmin());
    }

    match /api_usage_stats/{statId} {
      allow read: if true;
      allow write: if true;
    }
    match /raw_ai_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /ai_insights/{insightId} {
      allow read, write: if isAdmin();
    }

    match /system_prompts/{promptId} {
      allow read: if isSignedIn(); // In case client needs it, though server usually fetches it
      allow write: if isAdmin();
    }
  }
} 