{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "User account registration and request tracking",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "queryCount": { "type": "integer" },
        "latexCount": { "type": "integer" },
        "examCount": { "type": "integer" },
        "promptCount": { "type": "integer" },
        "lastLatexResetDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status", "queryCount", "latexCount", "examCount", "promptCount", "createdAt"]
    },
    "feedback": {
      "title": "User Feedback",
      "description": "User contributions, suggestions, ideas and bug reports",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "feedbackText": { "type": "string" },
        "type": { "type": "string", "enum": ["bug", "request", "suggestion", "other"] },
        "rating": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "version": { "type": "string" },
        "replyText": { "type": "string" },
        "replyAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "feedbackText", "type", "createdAt", "version"]
    },
    "notification": {
      "title": "System / Personal Notification",
      "description": "System notices and personal feedback replies sent to users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["system", "user", "feedback_reply"] },
        "targetUid": { "type": "string" },
        "targetEmail": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "type", "targetUid", "targetEmail", "senderName", "createdAt"]
    },
    "saved_document": {
      "title": "Saved Document",
      "description": "Word and PDF files manually saved by PRO users from LaTeX and QBuild",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["word", "pdf"] },
        "source": { "type": "string", "enum": ["latex", "qbuilder"] },
        "htmlContent": { "type": "string" },
        "wordFont": { "type": "string" },
        "fileSize": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "type", "source", "htmlContent", "createdAt"]
    },
    "raw_ai_log": {
      "title": "Raw AI Interaction Log",
      "description": "Raw inputs, outputs, and token counts for later analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "service": { "type": "string", "enum": ["latex", "qbuilder"] },
        "inputPrompt": { "type": "string" },
        "aiResponse": { "type": "string" },
        "inputTokens": { "type": "integer" },
        "outputTokens": { "type": "integer" },
        "totalTokens": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "analyzed"] }
      },
      "required": ["userId", "service", "inputPrompt", "aiResponse", "inputTokens", "outputTokens", "totalTokens", "createdAt", "status"]
    },
    "ai_insight": {
      "title": "AI Insight & Evaluation",
      "description": "AI-generated critique and prompt rewrite suggestions based on batch analysis",
      "type": "object",
      "properties": {
        "service": { "type": "string", "enum": ["latex", "qbuilder"] },
        "batchSize": { "type": "integer" },
        "batchTokens": { "type": "integer" },
        "critique": { "type": "string" },
        "score": { "type": "integer" },
        "proposedPrompt": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_approval", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "analyzedLogIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["service", "batchSize", "batchTokens", "critique", "score", "proposedPrompt", "status", "createdAt", "analyzedLogIds"]
    },
    "system_prompt": {
      "title": "Dynamic System Prompt",
      "description": "Active and versioned system prompts for AI services",
      "type": "object",
      "properties": {
        "service": { "type": "string", "enum": ["latex", "qbuilder"] },
        "action": { "type": "string" },
        "version": { "type": "integer" },
        "promptContent": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "insightId": { "type": "string" }
      },
      "required": ["service", "action", "version", "promptContent", "isActive", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User collection storing role, approval status and query usage counters"
    },
    "/feedbacks/{feedbackId}": {
      "schema": "feedback",
      "description": "Feedback collection storing user suggestions, ratings and replies"
    },
    "/notifications/{notificationId}": {
      "schema": "notification",
      "description": "General system notifications or specific replies to user's feedback submissions"
    },
    "/saved_documents/{documentId}": {
      "schema": "saved_document",
      "description": "Documents saved manually by PRO users containing compiled HTML content for Word or PDF download"
    },
    "/raw_ai_logs/{logId}": {
      "schema": "raw_ai_log",
      "description": "Short-lived raw interaction data for AI improvement tracking"
    },
    "/ai_insights/{insightId}": {
      "schema": "ai_insight",
      "description": "AI evaluations and suggested system prompts"
    },
    "/system_prompts/{promptId}": {
      "schema": "system_prompt",
      "description": "Current and historical system prompts used for AI generation"
    }
  }
}
