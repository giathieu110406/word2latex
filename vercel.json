{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ai.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/markitdown.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/approve-user.ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
