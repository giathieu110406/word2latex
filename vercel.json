{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ai.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/markitdown.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/approve-user.ts": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/ai-improvement.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/ai-improvement",
      "schedule": "0 */4 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
